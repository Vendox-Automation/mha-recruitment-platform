# Backend environment example — copy to backend/.env and adjust.
# Never commit real secrets (spec §22.5).

# Django
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database — PostgreSQL is the canonical/production database.
# Canonical (requires a running Postgres, e.g. via docker-compose):
DATABASE_URL=postgresql://mha:mha@localhost:5432/mha
# Local fallback when Postgres is unavailable (ADR-0001 §6) — uncomment to use:
# DATABASE_URL=sqlite:///./db.sqlite3

# Cross-origin / CSRF (Next.js dev origin)
FRONTEND_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email (dev uses the console backend by default)
DEFAULT_FROM_EMAIL=no-reply@mha-jobs.local

# Private media (resumes) — stored outside any public route
# PRIVATE_MEDIA_ROOT=

# Smart Job Fit AI explanation (optional, disabled by default — spec §16.7)
AI_JOB_FIT_ENABLED=false
AI_PROVIDER=
AI_MODEL=
AI_API_KEY=
