# Root environment example for docker-compose and shared local values.
# Copy to .env and adjust. Never commit real secrets (spec §22.5).
# Per-app examples also exist: backend/.env.example, frontend/.env.example.

# PostgreSQL (used by docker-compose and the backend DATABASE_URL).
POSTGRES_DB=mha
POSTGRES_USER=mha
POSTGRES_PASSWORD=mha
POSTGRES_PORT=5432
